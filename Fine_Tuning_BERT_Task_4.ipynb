    {
      "cell_type": "markdown",
      "source": [
        "**Data Loading, Preprocessing, and Splitting**"
      ],
      "metadata": {
        "id": "gE4OtoUagIwe"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "import kagglehub\n",
        "import pandas as pd\n",
        "from sklearn.model_selection import train_test_split\n",
        "# Download Dataset\n",
        "path=kagglehub.dataset_download(\"lakshmi25npathi/imdb-dataset-of-50k-movie-reviews\")\n",
        "df=pd.read_csv(f\"{path}/IMDB Dataset.csv\")\n",
        "# Preprocessing\n",
        "df['sentiment']=df['sentiment'].map({'positive': 1, 'negative': 0})\n",
        "df=df.dropna()\n",
        "df=df.sample(5000, random_state=42) # Sample 5,000 rows to speed up experiment\n",
        "# Data Splitting\n",
        "train_texts, temp_texts, train_labels, temp_labels = train_test_split(df['review'].tolist(), df['sentiment'].tolist(), test_size=0.2, random_state=42)\n",
        "val_texts, test_texts, val_labels, test_labels = train_test_split(temp_texts, temp_labels, test_size=0.5, random_state=42)\n",
        "\n",
        "print(f\"Train size: {len(train_texts)}, Validation size: {len(val_texts)}, Test size: {len(test_texts)}\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "6dIUM_z3f4oA",
        "outputId": "f0153bbd-0afe-4261-c2ca-60ce93580357"
      },
      "execution_count": 2,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Using Colab cache for faster access to the 'imdb-dataset-of-50k-movie-reviews' dataset.\n",
            "Train size: 4000, Validation size: 500, Test size: 500\n"
          ]
        }
      ]
    },
    {
      "cell_type": "markdown",
      "source": [
        "**Tokenization**"
      ],
      "metadata": {
        "id": "P-bT45DigLnh"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "from transformers import AutoTokenizer\n",
        "import torch\n",
        "\n",
        "# Load the pre-trained BERT tokenizer\n",
        "tokenizer=AutoTokenizer.from_pretrained(\"bert-base-uncased\")\n",
        "class IMDBDataset(torch.utils.data.Dataset):\n",
        "    def __init__(self, texts, labels):\n",
        "        self.encodings=tokenizer(texts, truncation=True, padding=True, max_length=256)\n",
        "        self.labels=labels\n",
        "\n",
        "    def __getitem__(self, idx):\n",
        "        item={key: torch.tensor(val[idx]) for key, val in self.encodings.items()}\n",
        "        item['labels']=torch.tensor(self.labels[idx])\n",
        "        return item\n",
        "\n",
        "    def __len__(self):\n",
        "        return len(self.labels)\n",
        "\n",
        "train_dataset=IMDBDataset(train_texts, train_labels)\n",
        "val_dataset=IMDBDataset(val_texts, val_labels)\n",
        "test_dataset=IMDBDataset(test_texts, test_labels)"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "2_Zr95vrf5SN",
        "outputId": "9d7bd53a-c737-468a-f608-93659bf2fe53"
      },
      "execution_count": 3,
